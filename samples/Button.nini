<script>
    texto = "Click me"
    
    class Boton
        fn click()
            print("Botón presionado!")
</script>

<button on_click="Boton.click">
    {texto}
</button>

<style>
    button:
        background: #4CAF50
        color: white
        padding: 0.8rem 1.5rem
        border: none
        border-radius: 4px
        cursor: pointer
        font-size: 1rem
    button:hover:
        background: #45a049
</style>
